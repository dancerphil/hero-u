{
  "name": "hero-u-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint-type": "pnpm --filter './packages/*' --bail run lint-type",
    "build": "pnpm --filter './packages/*' --bail run build",
    "test": "vitest run",
    "lint-all": "pnpm lint && pnpm lint-type",
    "prepare": "husky",
    "publish-all": "pnpm lint-all && pnpm --filter './packages/*' publish"
  },
  "devDependencies": {
    "@hero-u/eslint-config": "workspace:*",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.12.2"
}
