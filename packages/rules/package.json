    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.19.4",
    "vite": "^8.0.12"
